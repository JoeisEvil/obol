# LEDGER environment
# mock mode runs against an empty local registry — no keys required.
# Set LEDGER_MODE=live and provide a Stripe key per company to drive the real Stripe SDK.
LEDGER_MODE=mock

# Company Stripe keys — one per company you connect, only needed in live mode.
# Name each var STRIPE_KEY_<COMPANY_SLUG>, e.g.:
# STRIPE_KEY_ACME_AI=sk_live_...

# Stripe Connect (for OAuth-based client company connections) — optional
STRIPE_CONNECT_CLIENT_ID=ca_...
STRIPE_CONNECT_SECRET=sk_live_...

# Encryption key for stored Connect tokens (any 32-char string)
LEDGER_ENCRYPT_KEY=change_me_to_a_32_char_random_str

# NVIDIA / Nous Portal — only needed for live Hermes reasoning
NVIDIA_API_KEY=nvapi-...

# Dashboard + MCP HTTP wrapper
NEXT_PUBLIC_APP_URL=http://localhost:3000
MCP_HTTP_PORT=3001
NEXT_PUBLIC_MCP_HTTP_URL=http://localhost:3001

# Optional: gateway notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_ESCALATION_CHAT_ID=
